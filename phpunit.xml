<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Slice003">
            <directory>tests/slice-003</directory>
        </testsuite>
        <testsuite name="Slice004">
            <directory>tests/slice-004</directory>
        </testsuite>
        <testsuite name="Slice005">
            <directory>tests/slice-005</directory>
        </testsuite>
        <testsuite name="Slice006">
            <directory>tests/slice-006</directory>
        </testsuite>
        <testsuite name="Slice007">
            <directory>tests/slice-007</directory>
        </testsuite>
        <testsuite name="Slice008">
            <directory>tests/slice-008</directory>
        </testsuite>
        <testsuite name="Slice009">
            <directory>tests/slice-009</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="5433"/>
        <env name="DB_DATABASE" value="kalibrium_testing"/>
        <!-- Credenciais DE DEV LOCAL apenas: banco PostgreSQL isolado em 127.0.0.1:5433 -->
        <!-- usado somente pela suite de testes (kalibrium_testing). Produção usa secrets -->
        <!-- manager por ADR-0004 — estes valores nunca tocam produção. -->
        <!-- DB_PASSWORD é o default do container/scoop postgres local; não é secret. -->
        <env name="DB_USERNAME" value="postgres" force="false"/>
        <env name="DB_PASSWORD" value="postgres" force="false"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
