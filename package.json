{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "kalibrium-client",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "description": "Kalibrium offline-first mobile PWA client (slice-016 scaffold)",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint . --max-warnings=0",
        "test:e2e": "playwright test",
        "test:scaffold": "node --test tests/scaffold/*.test.cjs",
        "test": "npm run test:scaffold && npm run test:e2e",
        "generate:icons": "node scripts/pwa/generate-icons.mjs",
        "serve:https": "node scripts/pwa/serve-https.mjs --port 4173 --dir dist",
        "test:lighthouse": "node --test tests/scaffold/pwa-lighthouse.test.cjs"
    },
    "dependencies": {
        "@capacitor/android": "6.1.2",
        "@capacitor/core": "6.1.2",
        "@capacitor/ios": "6.1.2",
        "@ionic/react": "8.2.6",
        "@ionic/react-router": "8.2.6",
        "axios": "1.15.0",
        "ionicons": "7.4.0",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-router": "5.3.4",
        "react-router-dom": "5.3.4"
    },
    "devDependencies": {
        "@capacitor/cli": "6.1.2",
        "@playwright/test": "1.48.0",
        "@types/node": "20.14.10",
        "@types/react": "18.3.3",
        "@types/react-dom": "18.3.0",
        "@types/react-router": "5.1.20",
        "@types/react-router-dom": "5.3.3",
        "@typescript-eslint/eslint-plugin": "8.8.0",
        "@typescript-eslint/parser": "8.8.0",
        "@vitejs/plugin-react": "4.3.1",
        "eslint": "9.11.0",
        "eslint-config-prettier": "9.1.0",
        "eslint-plugin-react": "7.36.1",
        "eslint-plugin-react-hooks": "5.1.0",
        "globals": "15.9.0",
        "lighthouse": "12.2.0",
        "pngjs": "7.0.0",
        "prettier": "3.3.3",
        "pwa-asset-generator": "6.4.0",
        "serve": "14.2.4",
        "typescript": "5.4.5",
        "typescript-eslint": "8.8.0",
        "vite": "5.2.11",
        "vite-plugin-pwa": "0.20.5",
        "workbox-window": "7.3.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
