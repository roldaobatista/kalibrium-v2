{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec Audit Output",
  "description": "Schema para output do spec-auditor agent",
  "type": "object",
  "required": ["schema_version", "slice_id", "audit_date", "verdict", "summary", "checks", "findings", "stats"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "slice_id": { "type": "string", "pattern": "^slice-\\d{3}$" },
    "audit_date": { "type": "string", "format": "date" },
    "verdict": { "type": "string", "enum": ["approved", "rejected"] },
    "summary": { "type": "string", "minLength": 10 },
    "checks": {
      "type": "object",
      "required": ["scope_boundary", "ac_quality", "testability", "security_privacy", "dependencies", "product_alignment", "documentation_gate"],
      "additionalProperties": false,
      "properties": {
        "scope_boundary": { "$ref": "#/$defs/check" },
        "ac_quality": { "$ref": "#/$defs/check" },
        "testability": { "$ref": "#/$defs/check" },
        "security_privacy": { "$ref": "#/$defs/check" },
        "dependencies": { "$ref": "#/$defs/check" },
        "product_alignment": { "$ref": "#/$defs/check" },
        "documentation_gate": { "$ref": "#/$defs/check" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "location", "description", "recommendation"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^SP-\\d{3}$" },
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "category": {
            "type": "string",
            "enum": ["scope", "ac_quality", "testability", "security", "dependency", "product_alignment", "documentation_gate"]
          },
          "location": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "recommendation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stats": {
      "type": "object",
      "required": ["total_checks", "passed", "failed", "findings_critical", "findings_major", "findings_minor"],
      "additionalProperties": false,
      "properties": {
        "total_checks": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "findings_critical": { "type": "integer", "minimum": 0 },
        "findings_major": { "type": "integer", "minimum": 0 },
        "findings_minor": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["status", "details"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "details": { "type": "string", "minLength": 1 }
      }
    }
  }
}
