{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kalibrium.local/schemas/review.schema.json",
  "title": "Review Output",
  "description": "Schema do arquivo review.json produzido pelo sub-agent reviewer. Referenciado por R11 em docs/constitution.md. Independente do verification.json (R4) — reviewer e verifier operam em contextos isolados sem ver output um do outro.",
  "type": "object",
  "required": ["slice_id", "verdict", "timestamp", "quality_checks", "findings", "next_action"],
  "additionalProperties": false,
  "properties": {
    "slice_id": {
      "type": "string",
      "pattern": "^slice-[0-9]{3}$",
      "description": "Identificador do slice no formato slice-NNN"
    },
    "verdict": {
      "type": "string",
      "enum": ["approved", "rejected"],
      "description": "Veredito do reviewer. Binário."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC"
    },
    "quality_checks": {
      "type": "array",
      "minItems": 1,
      "description": "Resultado por categoria de qualidade avaliada.",
      "items": {
        "type": "object",
        "required": ["category", "status", "evidence"],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "duplication",
              "complexity",
              "naming",
              "security",
              "simplicity",
              "glossary",
              "adr_compliance",
              "dead_code"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "evidence": {
            "type": "string",
            "minLength": 1,
            "description": "Arquivo:linha ou descrição curta"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "description": "Lista de problemas encontrados. Pode ser vazia se verdict=approved.",
      "items": {
        "type": "object",
        "required": ["severity", "category", "file", "line", "message"],
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocker", "major", "minor"]
          },
          "category": {
            "type": "string",
            "enum": [
              "duplication",
              "complexity",
              "naming",
              "security",
              "simplicity",
              "glossary",
              "adr_compliance",
              "dead_code"
            ]
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 0
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "next_action": {
      "type": "string",
      "enum": ["approve_pr", "return_to_implementer", "escalate_human"],
      "description": "approve_pr = pronto para merge (combinado com verification.json approved). return_to_implementer = primeira rejeição. escalate_human = segunda rejeição consecutiva (R6)."
    }
  },
  "allOf": [
    {
      "description": "approved exige zero findings de severity blocker",
      "if": {
        "properties": { "verdict": { "const": "approved" } }
      },
      "then": {
        "properties": {
          "next_action": { "const": "approve_pr" },
          "findings": {
            "not": {
              "contains": {
                "properties": {
                  "severity": { "const": "blocker" }
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "rejected não pode ter next_action=approve_pr",
      "if": {
        "properties": { "verdict": { "const": "rejected" } }
      },
      "then": {
        "properties": {
          "next_action": {
            "enum": ["return_to_implementer", "escalate_human"]
          }
        }
      }
    },
    {
      "description": "qualquer finding com severity=blocker implica verdict=rejected",
      "if": {
        "properties": {
          "findings": {
            "contains": {
              "properties": {
                "severity": { "const": "blocker" }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "verdict": { "const": "rejected" }
        }
      }
    }
  ]
}
