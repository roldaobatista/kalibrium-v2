{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "DEPRECATED 2026-04-17 — substituido por docs/protocol/schemas/gate-output.schema.json (gate-output-v1, v1.2.4). Mantido somente para referencia historica. Novos gates (protocolo v1.2.2) validam contra o canonico unificado. Nenhum script do harness deve mais referenciar este arquivo.",
  "deprecated": true,
  "title": "[DEPRECATED] Guide Audit Report",
  "description": "Output schema for the guide-auditor sub-agent. Detects drift in harness configuration, orphaned files, disabled hooks, suspicious commits, and token blow-ups.",
  "type": "object",
  "required": [
    "audit_id",
    "timestamp",
    "verdict",
    "categories",
    "summary"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "description": "Unique identifier: guide-audit-YYYY-MM-DD-HHMMSS"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "clean",
        "warnings",
        "drift_detected"
      ],
      "description": "clean = no issues, warnings = minor items, drift_detected = action required"
    },
    "categories": {
      "type": "object",
      "required": [
        "sealed_files",
        "hooks_integrity",
        "forbidden_files",
        "git_identity",
        "telemetry",
        "orphan_instructions",
        "settings_drift",
        "token_usage",
        "r7_headers",
        "constitution_version"
      ],
      "properties": {
        "sealed_files": {
          "$ref": "#/$defs/category_result",
          "description": "Checks .claude/settings.json.sha256 and MANIFEST.sha256 integrity"
        },
        "hooks_integrity": {
          "$ref": "#/$defs/category_result",
          "description": "All hooks in MANIFEST exist and match checksums"
        },
        "forbidden_files": {
          "$ref": "#/$defs/category_result",
          "description": "R1: no .cursorrules, AGENTS.md, etc."
        },
        "git_identity": {
          "$ref": "#/$defs/category_result",
          "description": "R5: recent commits have valid authors"
        },
        "telemetry": {
          "$ref": "#/$defs/category_result",
          "description": "Telemetry files exist and are append-only"
        },
        "orphan_instructions": {
          "$ref": "#/$defs/category_result",
          "description": "No stray .md files with 'You are' / 'Your role' patterns outside .claude/"
        },
        "settings_drift": {
          "$ref": "#/$defs/category_result",
          "description": "settings.json matches sealed snapshot"
        },
        "token_usage": {
          "$ref": "#/$defs/category_result",
          "description": "No sub-agent exceeded declared budget"
        },
        "r7_headers": {
          "$ref": "#/$defs/category_result",
          "description": "docs/reference/** files have non-instructional headers"
        },
        "constitution_version": {
          "$ref": "#/$defs/category_result",
          "description": "constitution.md version matches CLAUDE.md reference"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_checks",
        "passed",
        "warnings",
        "failures"
      ],
      "properties": {
        "total_checks": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "type": "integer",
          "minimum": 0
        },
        "failures": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "priority",
          "action"
        ],
        "properties": {
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2"
            ]
          },
          "action": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "category_result": {
      "type": "object",
      "required": [
        "status",
        "findings"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "warning",
            "fail"
          ]
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "message"
            ],
            "properties": {
              "message": {
                "type": "string"
              },
              "file": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "info",
                  "warning",
                  "error"
                ]
              }
            }
          }
        }
      }
    }
  }
}
