# URL do servidor backend (Laravel).
# Em emulador Android: usar 10.0.2.2 (aponta pro localhost da máquina host).
# Em navegador / iOS simulator: usar 127.0.0.1 ou o IP da máquina na rede local.
VITE_API_BASE_URL=http://10.0.2.2:8000

# ID do cliente (tenant). Por enquanto fixo em 1.
# A escolha do tenant pelo técnico será implementada em história futura.
VITE_TENANT_ID=1
